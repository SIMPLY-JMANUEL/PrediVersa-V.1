# Configuración del Servidor
PORT=5000
NODE_ENV=development

# Configuración JWT
JWT_SECRET=tu_secreto_super_seguro_cambia_esto_en_produccion

# Configuración de Base de Datos MySQL (AWS RDS)
# Reemplaza estos valores con los de tu instancia RDS

# Host de la base de datos (endpoint de AWS RDS)
DB_HOST=your-rds-instance.region.rds.amazonaws.com

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# Nombre de la base de datos
DB_NAME=prediversa

# Usuario de la base de datos
DB_USER=admin

# Contraseña de la base de datos
DB_PASSWORD=your_secure_password

# SSL (requerido para AWS RDS)
# En producción con RDS, establecer como 'true'
DB_SSL=true

# ============================================
# INSTRUCCIONES DE CONFIGURACIÓN AWS RDS
# ============================================
# 
# 1. Crear instancia RDS en AWS Console:
#    - Engine: MySQL 8.0
#    - Template: Free tier (si aplica)
#    - DB instance identifier: prediversa-db
#    - Master username: admin
#    - Master password: (genera una segura)
#
# 2. Configurar Security Group:
#    - Agregar regla de entrada para MySQL (puerto 3306)
#    - Source: Tu IP o 0.0.0.0/0 (para desarrollo)
#
# 3. Obtener el endpoint:
#    - En RDS > Databases > tu instancia
#    - Copiar el "Endpoint" (sin el puerto)
#
# 4. Crear archivo .env:
#    - Copiar este archivo: cp .env.example .env
#    - Actualizar los valores con tus credenciales
#
# 5. Ejecutar script SQL:
#    - Conectarse a la base de datos
#    - Ejecutar: mysql -h [endpoint] -u admin -p < database/schema.sql
#
# ============================================
